                <ui:Button text="9" name="Boton9" class="dial-button" style="background-image: url(&quot;project://database/Assets/Sprites/Bloques/bloque_9.png?fileID=2800000&amp;guid=c27e450e4c1a949c98cff922ceefe833&amp;type=3#bloque_9&quot;);"/>
            </ui:VisualElement>
            <ui:VisualElement class="dial-row">
                <ui:VisualElement class="dial-spacer"/>
                <ui:Button text="0" name="Boton0" class="dial-button" style="background-image: url(&quot;project://database/Assets/Sprites/Bloques/bloque_cero.png?fileID=2800000&amp;guid=579d83654779a4b2eb853cf6e64b319c&amp;type=3#bloque_cero&quot;);"/>
