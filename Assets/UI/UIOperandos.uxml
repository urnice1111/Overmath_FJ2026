                <ui:Button text="2" name="Boton2" class="dial-button" style="background-image: url(&quot;project://database/Assets/Sprites/Bloques/bloque_2.png?fileID=2800000&amp;guid=d7d85a36b72734d47889d8474cd87011&amp;type=3#bloque_2&quot;);"/>
                <ui:Button text="3" name="Boton3" class="dial-button" style="background-image: url(&quot;project://database/Assets/Sprites/Bloques/bloque_3.png?fileID=2800000&amp;guid=b38f268a8114e4f81a3b1c99d3b29c46&amp;type=3#bloque_3&quot;);"/>
            </ui:VisualElement>
            <ui:VisualElement class="dial-row">
                <ui:Button text="4" name="Boton4" class="dial-button" style="background-image: url(&quot;project://database/Assets/Sprites/Bloques/bloque_4.png?fileID=2800000&amp;guid=7dcf575fdda494bbc9b36bbe77951b62&amp;type=3#bloque_4&quot;);"/>
                <ui:Button text="5" name="Boton5" class="dial-button" style="background-image: url(&quot;project://database/Assets/Sprites/Bloques/bloque_5.png?fileID=2800000&amp;guid=9de334279cf20469fbe7eaadb7fd1bad&amp;type=3#bloque_5&quot;);"/>
                <ui:Button text="6" name="Boton6" class="dial-button" style="background-image: url(&quot;project://database/Assets/Sprites/Bloques/bloque_6.png?fileID=2800000&amp;guid=193470079d5a040cc8f7f26f0b4ec849&amp;type=3#bloque_6&quot;);"/>
            </ui:VisualElement>
            <ui:VisualElement class="dial-row">
                <ui:Button text="7" name="Boton7" class="dial-button" style="background-image: url(&quot;project://database/Assets/Sprites/Bloques/bloque_7.png?fileID=2800000&amp;guid=f69c6b82b8b99413e885849e77825bb0&amp;type=3#bloque_7&quot;);"/>
