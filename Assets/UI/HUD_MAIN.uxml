<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="HUD" style="flex-grow: 1; picking-mode: ignore;">
        <ui:VisualElement name="TopLeftContainer" style="position: absolute; left: 20px; top: 20px; flex-direction: column; align-items: flex-start;">
            <ui:VisualElement style="flex-direction: row; align-items: center; margin-bottom: 5px;">
                <ui:VisualElement name="coin-icon" style="width: 64px; height: 64px; margin-right: 10px;"/>
                <ui:Label name="coin-label" text="0" class="text" style="font-size: 100px; color: rgb(255, 255, 255); -unity-font-definition: url(&quot;project://database/Assets/TextMesh%20Pro/Fonts/GrapeSoda.ttf?fileID=12800000&amp;guid=1c83ba9c46190e848b7c33e2673b8ccc&amp;type=3#GrapeSoda&quot;); -unity-text-outline-width: 4px; -unity-text-outline-color: rgb(0, 0, 0);"/>
            </ui:VisualElement>
            <ui:VisualElement style="flex-direction: row; align-items: center;">
                <ui:VisualElement name="trophy-icon" style="width: 64px; height: 64px; margin-right: 10px;"/>
                <ui:Label name="score-label" text="0" class="text" style="font-size: 100px; color: rgb(255, 255, 255); -unity-font-definition: url(&quot;project://database/Assets/TextMesh%20Pro/Fonts/GrapeSoda.ttf?fileID=12800000&amp;guid=1c83ba9c46190e848b7c33e2673b8ccc&amp;type=3#GrapeSoda&quot;); -unity-text-outline-width: 4px; -unity-text-outline-color: rgb(0, 0, 0);"/>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
